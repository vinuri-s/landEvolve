# Python bytecode caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
qt_env/
venv/
env/
ENV/

# Project outputs you mentioned
resources/outputs/

# Mypy cache
.mypy_cache/

# IDE/editor
.vscode/
.idea/

# Common extras
.DS_Store
.pytest_cache/

# DEM rasters: ignored by default, but the input DEMs are committed for
# reproducibility — except the oversized 1 m Wairewa raster (810 MB), which
# exceeds GitHub's 100 MB file limit and must be obtained separately / via LFS.
*.tif
!resources/inputs/**/*.tif
resources/inputs/wairewa/wairewa_catchment_1m.tif

# SQLite database — regenerated from app/data/seed.py on first run
app/data/db/*.db
app/data/db/*.db-shm
app/data/db/*.db-wal

dist/
build/
logs/backend.log
logs/ui.log
logs/engine.log
